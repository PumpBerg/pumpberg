# ── Pumpberg Configuration ──
# Copy this file to .env and fill in your own values.
# NEVER commit .env to git — it contains your private keys.

# Wallet (create via PumpPortal API or use your existing Solana wallet)
PUMP_TRADER_PRIVATE_KEY=your_base58_encoded_private_key_here
PUMP_TRADER_PUBLIC_KEY=your_solana_public_key_here
PUMP_TRADER_API_KEY=your_pumpportal_api_key_here

# Solana RPC (get a free endpoint from https://helius.dev or https://quicknode.com)
PUMP_TRADER_RPC_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY

# Mode is controlled from the dashboard toggle (defaults to DRY RUN on startup)

# Trading parameters (all editable at runtime via dashboard)
# PUMP_TRADER_STOP_LOSS_PCT=0.08
# PUMP_TRADER_TAKE_PROFIT_1_PCT=0.15
# PUMP_TRADER_TAKE_PROFIT_2_PCT=0.30

# Dashboard
PUMP_TRADER_DASHBOARD_PORT=3847

# Admin credentials (set on first run)
PUMP_TRADER_ADMIN_USERNAME=admin
PUMP_TRADER_ADMIN_PASSWORD=change_me_to_a_strong_password

# Anthropic API (for LLM token analysis — get a key at https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-your_key_here

